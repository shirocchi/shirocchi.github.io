---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'shirocchi';
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const desc = description ?? 'ノートと文章。';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#faf6ec" media="(prefers-color-scheme: light)" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={title ? 'article' : 'website'} />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'rpg') document.documentElement.dataset.theme = 'rpg';
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">{siteTitle}</a>
      <div class="header-right">
        <nav>
          <a href="/posts/">posts</a>
          <a href="/about/">about</a>
        </nav>
        <div class="theme-switch" role="group" aria-label="theme">
          <button type="button" data-set-theme="reading" aria-label="通常表示">通常</button>
          <span class="sep" aria-hidden="true">/</span>
          <button type="button" data-set-theme="rpg" aria-label="RPG表示">RPG</button>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© {new Date().getFullYear()}</span>
      <a href="/rss.xml">rss</a>
    </footer>
    <script>
      const root = document.documentElement;
      const buttons = document.querySelectorAll('[data-set-theme]');
      const sync = () => {
        const current = root.dataset.theme === 'rpg' ? 'rpg' : 'reading';
        buttons.forEach((b) => {
          const el = b as HTMLButtonElement;
          el.classList.toggle('active', el.dataset.setTheme === current);
        });
      };
      buttons.forEach((b) => {
        const el = b as HTMLButtonElement;
        el.addEventListener('click', () => {
          const t = el.dataset.setTheme === 'rpg' ? 'rpg' : 'reading';
          if (t === 'rpg') root.dataset.theme = 'rpg';
          else delete root.dataset.theme;
          try { localStorage.setItem('theme', t); } catch (e) {}
          sync();
        });
      });
      sync();
    </script>
  </body>
</html>
